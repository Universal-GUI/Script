local TextChatService = game:GetService("TextChatService")
local TweenService = game:GetService("TweenService")
local UserInputService = game:GetService("UserInputService")
local RunService = game:GetService("RunService")
local player = game.Players.LocalPlayer
local pGui = player:WaitForChild("PlayerGui")

if pGui:FindFirstChild("UltraSmoothChat") then pGui.UltraSmoothChat:Destroy() end

local screen = Instance.new("ScreenGui", pGui)
screen.Name = "UltraSmoothChat"

local mainFrame = Instance.new("Frame", screen)
mainFrame.Size = UDim2.new(0, 300, 0, 120)
mainFrame.Position = UDim2.new(0.5, -150, 0.85, 0)
mainFrame.BackgroundColor3 = Color3.fromRGB(0, 0, 0)
mainFrame.BackgroundTransparency = 0.3
mainFrame.BorderSizePixel = 0 -- Обводка убрана
mainFrame.Active = true

local mainCorner = Instance.new("UICorner", mainFrame)
mainCorner.CornerRadius = UDim.new(0, 12)

-- ЛОГИКА УЛЬТРА-ПЛАВНОГО ПЕРЕТАСКИВАНИЯ (LERP)
local dragSpeed = 0.15 -- Чем меньше число, тем плавнее (медленнее) догоняет
local dragInput, dragStart, startPos
local dragging = false
local targetPos = mainFrame.Position

mainFrame.InputBegan:Connect(function(input)
	if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
		dragging = true
		dragStart = input.Position
		startPos = mainFrame.Position
	end
end)

UserInputService.InputChanged:Connect(function(input)
	if dragging and (input.UserInputType == Enum.UserInputType.MouseMovement or input.UserInputType == Enum.UserInputType.Touch) then
		dragInput = input
	end
end)

UserInputService.InputEnded:Connect(function(input)
	if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
		dragging = false
	end
end)

RunService.RenderStepped:Connect(function()
	if dragging and dragInput then
		local delta = dragInput.Position - dragStart
		targetPos = UDim2.new(startPos.X.Scale, startPos.X.Offset + delta.X, startPos.Y.Scale, startPos.Y.Offset + delta.Y)
	end
	-- Плавное приближение к цели
	mainFrame.Position = mainFrame.Position:Lerp(targetPos, dragSpeed)
end)

-- ОСТАЛЬНЫЕ ЭЛЕМЕНТЫ
local textBox = Instance.new("TextBox", mainFrame)
textBox.Size = UDim2.new(1, -24, 0, 40)
textBox.Position = UDim2.new(0, 12, 0, 12)
textBox.PlaceholderText = "Введите текст..."
textBox.PlaceholderColor3 = Color3.fromRGB(180, 180, 180)
textBox.Text = ""
textBox.BackgroundColor3 = Color3.fromRGB(255, 255, 255)
textBox.BackgroundTransparency = 0.95
textBox.TextColor3 = Color3.fromRGB(255, 255, 255)
textBox.Font = Enum.Font.GothamMedium
textBox.TextSize = 14
textBox.ClearTextOnFocus = false
Instance.new("UICorner", textBox).CornerRadius = UDim.new(0, 8)

local toggleBtn = Instance.new("TextButton", mainFrame)
toggleBtn.Size = UDim2.new(1, -24, 0, 35)
toggleBtn.Position = UDim2.new(0, 12, 0, 65)
toggleBtn.Text = "ВЫБРАТЬ КАНАЛ"
toggleBtn.BackgroundColor3 = Color3.fromRGB(255, 255, 255)
toggleBtn.BackgroundTransparency = 0.9
toggleBtn.TextColor3 = Color3.fromRGB(255, 255, 255)
toggleBtn.Font = Enum.Font.GothamBold
toggleBtn.TextSize = 13
toggleBtn.ZIndex = 5
Instance.new("UICorner", toggleBtn).CornerRadius = UDim.new(0, 8)

local scroll = Instance.new("ScrollingFrame", mainFrame)
scroll.Size = UDim2.new(1, 0, 0, 0)
scroll.Position = UDim2.new(0, 0, 0, -10)
scroll.AnchorPoint = Vector2.new(0, 1)
scroll.BackgroundColor3 = Color3.fromRGB(0, 0, 0)
scroll.BackgroundTransparency = 1
scroll.Visible = false
scroll.ScrollBarThickness = 0
scroll.CanvasSize = UDim2.new(0, 0, 0, 0)
scroll.ZIndex = 10
Instance.new("UICorner", scroll).CornerRadius = UDim.new(0, 12)

local layout = Instance.new("UIListLayout", scroll)
layout.Padding = UDim.new(0, 6)
layout.HorizontalAlignment = Enum.HorizontalAlignment.Center
layout.VerticalAlignment = Enum.VerticalAlignment.Center

local padding = Instance.new("UIPadding", scroll)
padding.PaddingTop = UDim.new(0, 10)
padding.PaddingBottom = UDim.new(0, 10)

local currentChannel = nil
local isOpen = false

toggleBtn.MouseButton1Click:Connect(function()
	isOpen = not isOpen
	if isOpen then
		scroll.Visible = true
		TweenService:Create(scroll, TweenInfo.new(0.4, Enum.EasingStyle.Quart, Enum.EasingDirection.Out), {
			Size = UDim2.new(1, 0, 0, 150),
			BackgroundTransparency = 0.3
		}):Play()
	else
		local t = TweenService:Create(scroll, TweenInfo.new(0.3, Enum.EasingStyle.Quart, Enum.EasingDirection.In), {
			Size = UDim2.new(1, 0, 0, 0),
			BackgroundTransparency = 1
		})
		t:Play()
		t.Completed:Connect(function() if not isOpen then scroll.Visible = false end end)
	end
end)

local function addChannelButton(channel)
	local btn = Instance.new("TextButton", scroll)
	btn.Size = UDim2.new(0, 260, 0, 35)
	btn.Text = channel.Name:upper()
	btn.BackgroundColor3 = Color3.fromRGB(255, 255, 255)
	btn.BackgroundTransparency = 0.95
	btn.TextColor3 = Color3.fromRGB(255, 255, 255)
	btn.Font = Enum.Font.GothamBold
	btn.TextSize = 12
	btn.ZIndex = 11
	Instance.new("UICorner", btn).CornerRadius = UDim.new(0, 8)
	
	btn.MouseEnter:Connect(function()
		TweenService:Create(btn, TweenInfo.new(0.2), {BackgroundTransparency = 0.7}):Play()
	end)
	btn.MouseLeave:Connect(function()
		TweenService:Create(btn, TweenInfo.new(0.2), {BackgroundTransparency = 0.95}):Play()
	end)
	
	btn.MouseButton1Click:Connect(function()
		currentChannel = channel
		toggleBtn.Text = "КАНАЛ: " .. channel.Name:upper()
		isOpen = false
		local t = TweenService:Create(scroll, TweenInfo.new(0.3, Enum.EasingStyle.Quart, Enum.EasingDirection.In), {
			Size = UDim2.new(1, 0, 0, 0),
			BackgroundTransparency = 1
		})
		t:Play()
		t.Completed:Connect(function() scroll.Visible = false end)
	end)
	scroll.CanvasSize = UDim2.new(0, 0, 0, layout.AbsoluteContentSize.Y + 20)
end

local channels = TextChatService:WaitForChild("TextChannels"):GetChildren()
for _, chat in pairs(channels) do
	if chat:IsA("TextChannel") then
		addChannelButton(chat)
		if not currentChannel or chat.Name == "RBXGeneral" then
			currentChannel = chat
			toggleBtn.Text = "КАНАЛ: " .. chat.Name:upper()
		end
	end
end

textBox.FocusLost:Connect(function(enterPressed)
	if enterPressed and textBox.Text ~= "" and currentChannel then
		currentChannel:SendAsync(textBox.Text)
		textBox.Text = ""
	end
end)
