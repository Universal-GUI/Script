local playerGui = player:WaitForChild("PlayerGui")
task.spawn(function()
    local questGui = playerGui:WaitForChild("QuestMemoryInputUI", 10)
    local inputFrame = questGui and questGui:FindFirstChild("InputFrame", true)

    if not inputFrame then return end

    local sequence = {}
    local lastChangeTime = 0
    local originalColors = {}
    local isBotActing = false
    
    local changedInWindow = {}
    local waitingForWindow = false

    for _, btn in pairs(inputFrame:GetChildren()) do
        if btn:IsA("GuiObject") then
            originalColors[btn] = btn.BackgroundColor3
        end
    end

    local function clickButton(btn)
        local x = btn.AbsolutePosition.X + (btn.AbsoluteSize.X / 1.1)
        local y = btn.AbsolutePosition.Y + (btn.AbsoluteSize.Y / 2) + 58 
        VirtualInputManager:SendMouseButtonEvent(x, y, 0, true, game, 1)
        task.wait(0.05)
        VirtualInputManager:SendMouseButtonEvent(x, y, 0, false, game, 1)
    end

    local function handleWindowedChanges()
        waitingForWindow = true
        task.wait(0.05) 
        
        local count = 0
        local tempBtns = {}
        for btn, _ in pairs(changedInWindow) do
            count = count + 1
            table.insert(tempBtns, btn)
        end

        if count > 0 and count < 5 then
            for _, btn in ipairs(tempBtns) do
                table.insert(sequence, btn)
                lastChangeTime = tick()
            end
        end

        changedInWindow = {}
        waitingForWindow = false
    end

    local function playSequence()
        if #sequence == 0 or isBotActing then return end
        isBotActing = true
        
        task.wait(0.8)

        for _, btn in ipairs(sequence) do
            clickButton(btn)
            task.wait(0.4)
        end

        sequence = {}
        task.wait(1) 
        isBotActing = false
    end

    for _, btn in pairs(inputFrame:GetChildren()) do
        if btn:IsA("GuiObject") then
            btn:GetPropertyChangedSignal("BackgroundColor3"):Connect(function()
                if not isBotActing and btn.BackgroundColor3 ~= originalColors[btn] then
                    changedInWindow[btn] = true
                    if not waitingForWindow then
                        task.spawn(handleWindowedChanges)
                    end
                end
            end)
        end
    end

    while true do
        task.wait(0.2)
        if #sequence > 0 and (tick() - lastChangeTime) > 1.5 and not isBotActing then
            playSequence()
        end
    end
end)
end)
