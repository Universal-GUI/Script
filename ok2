local pages = {}
local function createTab(name, isDefault)
    local tabBtn = Instance.new("TextButton", sideBar)
    tabBtn.Size = UDim2.new(1, 0, 0, 35)
    tabBtn.Text = name:upper()
    tabBtn.BackgroundColor3, tabBtn.BackgroundTransparency = COLORS.ButtonBG, isDefault and 0.9 or 0.98
    tabBtn.TextColor3 = isDefault and COLORS.Text or COLORS.InactiveText
    tabBtn.Font, tabBtn.TextSize = Enum.Font.GothamBold, 10
    Instance.new("UICorner", tabBtn).CornerRadius = UDim.new(0, 8)

    local page = Instance.new("ScrollingFrame", container)
    page.Size, page.Position, page.BackgroundTransparency, page.Visible = UDim2.new(1, 0, 1, -10), UDim2.new(0,0,0,35), 1, isDefault
    page.ScrollBarThickness = 0
    Instance.new("UIListLayout", page).Padding = UDim.new(0, 10)
    
    pages[name] = {btn = tabBtn, page = page}
    tabBtn.MouseButton1Click:Connect(function()
        for _, data in pairs(pages) do
            data.page.Visible = false
            TweenService:Create(data.btn, TweenInfo.new(0.3), {BackgroundTransparency = 0.98, TextColor3 = COLORS.InactiveText}):Play()
        end
        page.Visible = true
        TweenService:Create(tabBtn, TweenInfo.new(0.3), {BackgroundTransparency = 0.9, TextColor3 = COLORS.Text}):Play()
    end)
    return page
end

