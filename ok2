local function addButton(parent, text, hint, color, callback)
    local btn = Instance.new("TextButton", parent)
    btn.Size = UDim2.new(1, -5, 0, 45)
    btn.BackgroundColor3 = color or COLORS.ButtonBG
    btn.BackgroundTransparency = color and 0.85 or 0.95
    btn.Text = ""
    btn.AutoButtonColor = true
    Instance.new("UICorner", btn).CornerRadius = UDim.new(0, 8)
    
    local titleLabel = Instance.new("TextLabel", btn)
    titleLabel.Size = UDim2.new(1, 0, 0, 25)
    titleLabel.Position = UDim2.new(0, 0, 0, 4)
    titleLabel.BackgroundTransparency, titleLabel.Text, titleLabel.TextColor3 = 1, text:upper(), COLORS.Text
    titleLabel.Font, titleLabel.TextSize = Enum.Font.GothamBold, 11

    local hintLabel = Instance.new("TextLabel", btn)
    hintLabel.Size = UDim2.new(1, 0, 0, 15)
    hintLabel.Position = UDim2.new(0, 0, 0, 24)
    hintLabel.BackgroundTransparency, hintLabel.Text, hintLabel.TextColor3 = 1, hint, COLORS.HintText
    hintLabel.Font, hintLabel.TextSize = Enum.Font.GothamMedium, 9
    
    btn.MouseButton1Click:Connect(callback)
    btn.MouseEnter:Connect(function() TweenService:Create(btn, TweenInfo.new(0.2), {BackgroundTransparency = 0.8}):Play() end)
    btn.MouseLeave:Connect(function() TweenService:Create(btn, TweenInfo.new(0.2), {BackgroundTransparency = color and 0.85 or 0.95}):Play() end)
    -- Вставь это в конец функции addButton:
    parent.CanvasSize = UDim2.new(0, 0, 0, parent.UIListLayout.AbsoluteContentSize.Y + 10)
end

