    for _, child in pairs(mainFrame:GetDescendants()) do
        -- Работаем с фоном (Frame, Button) и текстом (Label, Button)
        local isGui = child:IsA("GuiObject")
        local isText = child:IsA("TextLabel") or child:IsA("TextButton")
        
        if isGui then
            -- Если мы еще не запомнили прозрачность этого объекта — запоминаем её
            if originalTrans[child] == nil then
                originalTrans[child] = {
                    bg = child.BackgroundTransparency,
                    txt = isText and child.TextTransparency or 0
                }
            end
            
            -- Возвращаем к оригиналу или уводим в 1
            local targetBg = menuVisible and originalTrans[child].bg or 1
            TweenService:Create(child, TweenInfo.new(0.3), {BackgroundTransparency = targetBg}):Play()
            
            if isText then
                local targetTxt = menuVisible and originalTrans[child].txt or 1
                TweenService:Create(child, TweenInfo.new(0.3), {TextTransparency = targetTxt}):Play()
            end
        end
    end

    if menuVisible then mainFrame.Visible = true end
    task.delay(0.3, function()
