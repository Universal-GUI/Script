local function makeDraggable(frame)
    local UserInputService = game:GetService("UserInputService")
    local RunService = game:GetService("RunService")

    local dragging = false
    local dragStart, startPos
    local targetPos = frame.Position -- Целевая позиция, к которой будем стремиться
    local dragSpeed = 0.2 -- Скорость доводки (от 0.1 до 1). Чем меньше, тем плавнее.

    -- Когда нажали на фрейм
    frame.InputBegan:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
            dragging = true
            dragStart = input.Position
            startPos = frame.Position
            
            -- Отключаем перетаскивание при отпускании
            local connection
            connection = UserInputService.InputEnded:Connect(function(inputEnded)
                if inputEnded == input or inputEnded.UserInputType == Enum.UserInputType.MouseButton1 or inputEnded.UserInputType == Enum.UserInputType.Touch then
                    dragging = false
                    connection:Disconnect()
                end
            end)
        end
    end)

    -- Обновляем целевую позицию при движении
    UserInputService.InputChanged:Connect(function(input)
        if dragging and (input.UserInputType == Enum.UserInputType.MouseMovement or input.UserInputType == Enum.UserInputType.Touch) then
            local delta = input.Position - dragStart
            targetPos = UDim2.new(
                startPos.X.Scale, 
                startPos.X.Offset + delta.X, 
                startPos.Y.Scale, 
                startPos.Y.Offset + delta.Y
            )
        end
    end)

    -- Каждый кадр плавно двигаем рамку к цели
    RunService.RenderStepped:Connect(function()
        if frame.Position ~= targetPos then
            -- Метод Lerp делает переход между текущей позицией и целью мягким
            frame.Position = frame.Position:Lerp(targetPos, dragSpeed)
        end
    end)
end

