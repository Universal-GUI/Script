local function createStyledFrame(size, pos, titleText)
    local frame = Instance.new("Frame", screen)
    frame.Size, frame.Position = size, pos
    frame.BackgroundColor3, frame.BackgroundTransparency = COLORS.MainBG, COLORS.Transparency
    frame.BorderSizePixel = 0
    Instance.new("UICorner", frame).CornerRadius = UDim.new(0, 12)
    makeDraggable(frame)
    local title = Instance.new("TextLabel", frame)
    title.Size, title.BackgroundTransparency = UDim2.new(1, 0, 0, 40), 1
    title.Text, title.TextColor3 = titleText:upper(), COLORS.Text
    title.Font, title.TextSize = Enum.Font.GothamBold, 12
    return frame
end

